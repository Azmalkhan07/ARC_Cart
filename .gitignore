.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local

# IDE and System files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
